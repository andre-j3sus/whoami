---
import { getLangFromUrl, useTranslations, getDateLocale } from "@/i18n/utils";
import { formatYearMonth } from "@/utils/dates";

interface Props {
  startDate: string;
  endDate?: string;
}

const { startDate, endDate } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);
---

{endDate ? (
  <Fragment>
    <time datetime={startDate}>{formatYearMonth(startDate, dateLocale)}</time>&thinsp;&ndash;&thinsp;<time datetime={endDate}>{formatYearMonth(endDate, dateLocale)}</time>
  </Fragment>
) : (
  <Fragment>
    <time datetime={startDate}>{formatYearMonth(startDate, dateLocale)}</time>&thinsp;&ndash;&thinsp;<span>{t("common.present")}</span>
  </Fragment>
)}
