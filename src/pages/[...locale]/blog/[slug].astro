---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { personal } from "@/data/personal";
import { getCollection, render } from "astro:content";
import { getLangFromUrl, useTranslations, useTranslatedPath, getBlogPostSlug, getDateLocale } from "@/i18n/utils";

export async function getStaticPaths() {
  const isDev = import.meta.env.DEV;
  const posts = await getCollection("blog", ({ data }) =>
    !data.externalUrl && (isDev || !data.draft)
  );

  /* EN posts without a PT counterpart also get a /pt/ route (EN content, PT chrome) */
  const ptSlugs = new Set(
    posts.filter((p) => p.id.startsWith("pt/")).map((p) => getBlogPostSlug(p.id))
  );

  return posts.flatMap((post) => {
    const [lang, ...slugParts] = post.id.split("/");
    const slug = slugParts.join("/");
    const paths = [
      { params: { locale: lang === "en" ? undefined : lang, slug }, props: { post } },
    ];
    if (lang === "en" && !ptSlugs.has(slug)) {
      paths.push({ params: { locale: "pt", slug }, props: { post } });
    }
    return paths;
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const dateLocale = getDateLocale(lang);
const baseSlug = getBlogPostSlug(post.id);

/* -- Check for a translation pair --------------------------------------- */
const allPosts = await getCollection("blog", ({ data }) => !data.externalUrl);
const otherLang = lang === "en" ? "pt" : "en";
const translationPair = allPosts.find((p) => getBlogPostSlug(p.id) === baseSlug && p.id.startsWith(`${otherLang}/`));
const translationUrl = translationPair
  ? useTranslatedPath(otherLang)(`/blog/${baseSlug}`)
  : null;
---

<BaseLayout title={`${post.data.title} - ${personal.name}`} description={post.data.description} ogType="article" ogImage={post.data.ogImage}>
  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-1 z-[60] bg-[var(--color-accent)]" style="width: 0%;"></div>

  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 sm:py-20">
    <header class="mb-10">
      <a
        href={translatePath("/blog")}
        class="mb-4 inline-flex items-center gap-1 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
      >
        <Icon name="lucide:arrow-left" size={16} />
        {t("blog.backToBlog")}
      </a>
      {post.data.draft && (
        <div class="mb-4 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-600 dark:text-amber-400">
          {t("blog.draftNotice")}
        </div>
      )}
      <h1 class="text-3xl font-bold sm:text-4xl">{post.data.title}</h1>
      <div class="mt-3 flex items-center gap-4 text-sm text-[var(--color-text-muted)]">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString(dateLocale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      </div>
      {(post.data.tags.length > 0 || translationUrl) && (
        <div class="mt-3 flex flex-wrap items-center gap-1.5">
          {post.data.tags.map((tag) => (
            <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 text-xs text-[var(--color-text-muted)]">
              {tag}
            </span>
          ))}
          {translationUrl && (
            <Fragment>
              <span class="flex-1" />
              <a
                href={translationUrl}
                class="rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent-light)] px-3 py-0.5 text-xs font-medium text-[var(--color-accent)] hover:border-[var(--color-accent)]/60 transition-colors inline-flex items-center gap-1.5"
              >
                <Icon name="lucide:languages" size={12} />
                {t("blog.readInOtherLang")}
              </a>
            </Fragment>
          )}
        </div>
      )}
    </header>

    {post.data.ogImage && (
      <div class="mb-10 overflow-hidden rounded-xl border border-[var(--color-border)]">
        <img
          src={post.data.ogImage}
          alt={post.data.title}
          width={1200}
          height={630}
          loading="eager"
          class="w-full object-cover"
          style="aspect-ratio: 1200/630;"
        />
      </div>
    )}

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>

  <script is:inline>
    (function () {
      var bar = document.getElementById("reading-progress");
      if (!bar) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        bar.style.display = "none";
        return;
      }
      window.addEventListener("scroll", function () {
        var h = document.documentElement;
        var progress = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
        bar.style.width = Math.min(progress, 100) + "%";
      }, { passive: true });
    })();
  </script>
</BaseLayout>
